# ============================================================================
# Visa Kit Backend — env переменные
# ============================================================================
# Локальная разработка: скопируй этот файл как .env и заполни значения
# Production (Railway): настраивается через UI Railway → Variables

# === Database ===
# Local SQLite (dev):
DATABASE_URL=sqlite:///./dev.db
# Production PostgreSQL (Railway автоматически подставит):
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# === Frontend URL ===
# Для CORS и magic-links клиентского кабинета
# Local: http://localhost:3000
# Production: https://your-app.vercel.app
FRONTEND_URL=http://localhost:3000

# === JWT Secret ===
# КРИТИЧНО: в production сгенерировать новый!
# python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=dev-secret-change-in-production-please
SECRET_KEY=dev-secret-change-in-production-please

# === Storage Backend ===
# "local" — файлы на диске (для dev)
# "r2" — Cloudflare R2 (для production)
STORAGE_BACKEND=local
STORAGE_PATH=storage

# === Cloudflare R2 (только если STORAGE_BACKEND=r2) ===
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# === Anthropic API (для LLM рекомендаций) ===
ANTHROPIC_API_KEY=

# === Templates path (опционально) ===
# По умолчанию ищет в visa_kit/templates/
# В Docker — /app/templates
# TEMPLATES_PATH=/app/templates
